            <ECUC-CONTAINER-VALUE>
              <SHORT-NAME>CanController_1</SHORT-NAME>
              <PARAMETER-VALUES>
                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF>/Can/CanController/CanControllerId</DEFINITION-REF>
                  <VALUE>1</VALUE>
                </ECUC-NUMERICAL-PARAM-VALUE>
                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF>/Can/CanController/CanControllerBaudRate</DEFINITION-REF>
