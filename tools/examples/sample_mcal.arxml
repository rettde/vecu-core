              <PARAMETER-VALUES>
                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF>/Can/CanHardwareObject/CanObjectId</DEFINITION-REF>
                  <VALUE>1</VALUE>
                </ECUC-NUMERICAL-PARAM-VALUE>
              </PARAMETER-VALUES>
            </ECUC-CONTAINER-VALUE>
          </CONTAINERS>
        </ECUC-MODULE-CONFIGURATION-VALUES>

        <!-- ══ ETH ══════════════════════════════════════════════ -->
        <ECUC-MODULE-CONFIGURATION-VALUES>
          <SHORT-NAME>Eth</SHORT-NAME>
          <CONTAINERS>
            <ECUC-CONTAINER-VALUE>
