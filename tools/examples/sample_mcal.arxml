<AUTOSAR xmlns="http://autosar.org/schema/r4.0">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>McalConfig</SHORT-NAME>
      <ELEMENTS>

        <!-- ══ CAN ══════════════════════════════════════════════ -->
        <ECUC-MODULE-CONFIGURATION-VALUES>
          <SHORT-NAME>Can</SHORT-NAME>
          <CONTAINERS>
            <ECUC-CONTAINER-VALUE>
              <SHORT-NAME>CanController_0</SHORT-NAME>
              <PARAMETER-VALUES>
